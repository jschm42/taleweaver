      "walkthrough": {
        "version": "compact-v2",
        "preview": "Hidden path for Crazy Job Interview: Pass the Cerberus (Get Past Crystal) -> Sign the Employment Contract",
        "steps": [
          {
            "title": "Pass the Cerberus (Get Past Crystal)",
            "content": "Present [[ITEM:FILLED_FORM_A38|Filled Form A38 (Organic Signature)]] to RECEPTIONIST_CRYSTAL and have her open door to CONFERENCE_POOL. Outcome target: The door to the Conference Pool is unlocked; Crystal will let Arthur proceed."
          },
          {
            "title": "Sign the Employment Contract",
            "content": "Obtain signatures from GWENDOLYN_WATERJET, MAJOR_FLUSH_MILLER, and FINNLEY_TECHBRO on [[ITEM:EMPLOYMENT_CONTRACT|Employment Contract (Unsigned)]]. Outcome target: Arthur becomes an employee of AquaTech Synergies LLC (or at least has the contract to prove it). The game ends when the contract is signed and Arthur exits with it."
          },
          {
            "title": "Gwendolyn's Karma Cleansing",
            "content": "Use [[ITEM:FENG_SHUI_STENCIL|Feng Shui Stencil]] and [[ITEM:INCENSE_STICK_DAMP_BASEMENT|Incense Stick \u2014 Scent: Damp Basement]] at the sink to reveal [[ITEM:CLEANSED_SINK|Cleansed Sink (Harmonic Resonance Achieved)]]. Outcome target: Gwendolyn is moved to tears and will sign the contract once the sink is cleansed (if pleased by Arthur's answers)."
          },
          {
            "title": "Major Miller's Bomb Defusal",
            "content": "Use [[ITEM:TACTICAL_TOILET_PAPER|Tactical Toilet Paper (Camouflage Pattern)]] and [[ITEM:RUBBER_DUCK_MICROCHIP|Rubber Duck with a Microchip]] at the boiler (BOILER_CLOSET) to reveal [[ITEM:STABILIZED_BOILER|Stabilized Boiler (Tick Converted to Squeak)]]. Outcome target: Major Miller recognizes Arthur's field ingenuity and will sign the contract after the boiler is stabilized."
          },
          {
            "title": "Finnley's Disruptive Innovation Test",
            "content": "Combine [[ITEM:PLUNGER_STANDARD|Standard Plunger]] and [[ITEM:OLD_SMARTPHONE_2013|Arthur's Old, Almost Dead Smartphone]] to create the [[ITEM:IPLUNGE_2000|iPlunge 2000 (Prototype)]] prototype and present it to FINNLEY_TECHBRO. Outcome target: Finnley is delighted by the grafting of tech onto old hardware and will sign the contract if convinced."
          }
        ]
      }
    },
