      "quests": [
        {
          "id": "PASS_RECEPTION",
          "title": "Pass the Cerberus (Get Past Crystal)",
          "description": "Crystal demands a properly signed Form A38 before she'll open the interview door. Arthur must provide an 'organic' signature to convince her.",
          "goal": "Present FILLED_FORM_A38 to RECEPTIONIST_CRYSTAL and have her open door to CONFERENCE_POOL.",
          "impact": "The door to the Conference Pool is unlocked; Crystal will let Arthur proceed.",
          "exp_reward": 200,
          "is_main": true,
          "status": "open"
        },
        {
          "id": "GET_CONTRACT_SIGNED",
          "title": "Sign the Employment Contract",
          "description": "Convince Gwendolyn, Major Miller, and Finnley to sign the contract. Each interviewer has a bizarre practical test\u2014pass all three and the contract is yours.",
          "goal": "Obtain signatures from GWENDOLYN_WATERJET, MAJOR_FLUSH_MILLER, and FINNLEY_TECHBRO on EMPLOYMENT_CONTRACT.",
          "impact": "Arthur becomes an employee of AquaTech Synergies LLC (or at least has the contract to prove it). The game ends when the contract is signed and Arthur exits with it.",
          "exp_reward": 400,
          "is_main": true,
          "status": "open"
        },
        {
          "id": "CLEANSE_SINK",
          "title": "Gwendolyn's Karma Cleansing",
          "description": "Gwendolyn forbids chemical cleaners or brute force. The sink must 'sing' and be cleansed by aligning its flow.",
          "goal": "Use FENG_SHUI_STENCIL and INCENSE_STICK_DAMP_BASEMENT at the sink to reveal CLEANSED_SINK.",
          "impact": "Gwendolyn is moved to tears and will sign the contract once the sink is cleansed (if pleased by Arthur's answers).",
          "exp_reward": 120,
          "is_main": false,
          "status": "open"
        },
        {
          "id": "DEFUSE_BOILER",
          "title": "Major Miller's Bomb Defusal",
          "description": "The boiler in Sector 7G is ticking and leaking. Miller wants immediate, creative action that demonstrates tactical ingenuity.",
          "goal": "Use TACTICAL_TOILET_PAPER and RUBBER_DUCK_MICROCHIP at the boiler (BOILER_CLOSET) to reveal STABILIZED_BOILER.",
          "impact": "Major Miller recognizes Arthur's field ingenuity and will sign the contract after the boiler is stabilized.",
          "exp_reward": 150,
          "is_main": false,
          "status": "open"
        },
        {
          "id": "BUILD_IPLUNGE",
          "title": "Finnley's Disruptive Innovation Test",
          "description": "Finnley wants a 'blockchain-ready plunger' on the spot. He will judge Arthur on ingenuity and buzzword fluency.",
          "goal": "Combine PLUNGER_STANDARD and OLD_SMARTPHONE_2013 to create the IPLUNGE_2000 prototype and present it to FINNLEY_TECHBRO.",
          "impact": "Finnley is delighted by the grafting of tech onto old hardware and will sign the contract if convinced.",
          "exp_reward": 100,
          "is_main": false,
          "status": "open"
        }
      ],
      "awards": [
        {
          "key": "ORGANIC_SIGNER",
          "title": "Organic Signer",
          "description": "You forged a convincingly organic signature using bakery goods and improvised tools.",
          "tier": "bronze",
          "requirement": "Create FILLED_FORM_A38 using VEGAN_MATCHA_MUFFIN + PIPE_WRENCH_HEAVY and present it to CRYSTAL."
        },
        {
          "key": "ZEN_MASTER_PLUMBER",
          "title": "Zen Master Plumber",
          "description": "You soothed a clogged sink with ritualistic precision and no brute force.",
          "tier": "silver",
          "requirement": "Reveal CLEANSED_SINK by combining FENG_SHUI_STENCIL + INCENSE_STICK_DAMP_BASEMENT and complete GWENDOLYN_WATERJET's test without using tools to dismantle the pipe."
        },
        {
          "key": "FIELD_ENGINEER",
          "title": "Field Engineer",
          "description": "You stabilized a ticking boiler with only duct tape-level ingenuity and battlefield toilet paper.",
          "tier": "silver",
          "requirement": "Reveal STABILIZED_BOILER by combining TACTICAL_TOILET_PAPER + RUBBER_DUCK_MICROCHIP and prevent any 'detonation' (no more than one simulated overflow)."
        },
        {
          "key": "DISRUPTIVE_MINIMALIST",
          "title": "Disruptive Minimalist",
          "description": "You built a 'game-changing' product out of a broken phone and a plunger and sold the pitch convincingly.",
          "tier": "gold",
          "requirement": "Assemble IPLUNGE_2000 from PLUNGER_STANDARD + OLD_SMARTPHONE_2013 and secure FINNLEY_TECHBRO's signature without using buzzwords suggested by prompts."
        },
        {
          "key": "COFFEE_SOAK_SURVIVOR",
          "title": "Coffee-Soak Survivor",
          "description": "Ed's coffee is a constant hazard \u2014 you emerged mostly dry and with your dignity intact.",
          "tier": "bronze",
          "requirement": "Complete the interview (GET_CONTRACT_SIGNED) having been splashed by Ed the Zombie Butler fewer than three times."
        }
      ],
