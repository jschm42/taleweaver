  "scenes": [
    {
      "id": "WAITING_ROOM",
      "name": "Waiting Room of Madness",
      "description": "A sterile, fluorescent-lit waiting area with mismatched bean bags, a broken coffee machine that drips ominously, and a reception desk plastered with incomprehensible HR posters. A faded magazine lies open with a Feng Shui stencil stuck in its pages.",
      "image_url": null
    },
    {
      "id": "RECEPTION_DESK",
      "name": "Reception Desk Corridor",
      "description": "A narrow corridor dominated by a tall reception counter where Crystal holds court. A stack of forms labeled 'Form for Intergalactic Vibrational Compatibility (Permit A38)' sits under a plastic pen holder that is very obviously out of ink.",
      "image_url": null
    },
    {
      "id": "CONFERENCE_POOL",
      "name": "The Conference Pool",
      "description": "A vast interview room whose conference table is an enormous repurposed hot tub (dry). Three high lifeguard chairs ring the tub. A sarcastic parrot's perch is mounted on the north lifeguard chair. A refreshment trolley sits at the side, perpetually at risk of a coffee spill.",
      "image_url": null
    },
    {
      "id": "TEST_SANITARY_CELL_7G",
      "name": "Test Sanitary Cell (Sector 7G)",
      "description": "A bathroom designed by someone who took modern art and plumbing to extremes: pipes loop like abstract sculptures, a neon-blue toilet glows in the corner, and a boiler ticks and hisses behind a grate with ominous theatricality.",
      "image_url": null
    },
    {
      "id": "BOILER_CLOSET",
      "name": "Boiler Maintenance Closet",
      "description": "A cramped closet full of valve wheels, a half-empty roll of tactical toilet paper, and an industrial-grade rubber duck affixed to a shelf. A faint, nervous ticking echoes from a covered boiler panel.",
      "image_url": null
    }
  ],
