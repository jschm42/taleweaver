{
  "version": "1.0",
  "id": "kitchen_crisis",
  "title": "Kitchen Crisis - The Sitcom Edition",
  "subtitle": "The Miller Family Meltdown",
  "description": "A 90s sitcom-style dinner disaster: bright colors, high stakes over trivial things, and frequent 'Oh you!' moments.",
  "story_idea": "\"The Miller Family Meltdown.\" It's 18:00 on a Tuesday. Grandma is coming for dinner in one hour, and the household is a disaster zone. A laugh track punctuates every failure. You play as the \"Last Sane Person\" (or the biggest chaos agent) trying to get the legendary Casserole ready while managing a cast of eccentric family members and a very persistent neighbor.",
  "tone": "90s Sitcom / Absurd Comedy",
  "image_style": "Bright, warm colors, slight VHS grain; comedic, high-contrast lighting",
  "pacing": {
    "scene_length": "short",
    "event_frequency": "high",
    "notes": "Fast comedic beats, quick scene cuts, frequent interruptions"
  },
  "protagonist": {
    "name": "Last Sane Person",
    "role": "Player character (household manager)",
    "description": "Trying to prepare the legendary Casserole under absurd pressure and keep the family from imploding.",
    "image_hint": "exasperated person in a bright cluttered kitchen, 90s sitcom lighting, humorous expression"
  },
  "characters": [
    {
      "id": "DAD_ARTHUR",
      "name": "Dad Arthur",
