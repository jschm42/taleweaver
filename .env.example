# App Configuration
PROJECT_NAME="TaleWeaver"
LOG_LEVEL=INFO

# Database defaults to a local SQLite file in the data folder
# DATABASE_URL="sqlite+aiosqlite:///./data/taleweaver.db"

# Security (Required for API Key Encryption in the DB)
# Run `python scripts/generate_fernet_key.py` to generate a valid base64 key
# and paste it exactly here without quotes:
ENCRYPTION_KEY=

# Storage
DATA_DIR=data

# Provider API Keys (Optional)
# If set here, these keys take precedence over database-stored keys
# and are marked as 'READ-ONLY' in the Admin UI.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# MISTRAL_API_KEY=...
# GROQ_API_KEY=gsk_...
# BLACK_FOREST_LABS_API_KEY=...
# MIDJOURNEY_API_KEY=...
