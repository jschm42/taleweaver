      "scenes": [
        {
          "id": "MODERN_KITCHEN",
          "name": "The Modern Kitchen",
          "description": "This glossy, chaotic kitchen is filled with half-cooked meals, smoking pans, and one very stressed family. A bright light flickers over the countertop, illuminating a casserole dish that smells just slightly wrong."
        },
        {
          "id": "LIVING_ROOM",
          "name": "The Living Room",
          "description": "Gramps sits heavily in his recliner. The massive TV blares reruns while the sofa bulges suspiciously. Every surface is covered in either snack crumbs or remote controls."
        },
        {
          "id": "HALLWAY",
          "name": "The Hallway",
          "description": "A corridor plastered with family photos and achievement certificates. One particularly large 'Wedding Photo' doesn\u2019t quite sit flush against the wall."
        },
        {
          "id": "MASTER_BEDROOM",
          "name": "The Master Bedroom",
          "description": "A strictly off-limits sanctuary filled with floral-scented candles, laundry piles, and one mysterious locked drawer labeled 'DO NOT TOUCH'."
        },
        {
          "id": "MYSTERY_BASEMENT",
          "name": "The Mystery Basement",
          "description": "A dim, cobwebbed underworld where half-finished projects lie forgotten. Tools rust, and an eerie hum can be heard from the far corner."
        }
      ],
