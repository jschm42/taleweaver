  "adventure": {
    "title": "The RPG Testing Grounds",
    "teaser": "A controlled environment for testing equipment, consumables, and combat mechanics.",
    "context": "The Testing Grounds is a magical pocket dimension created by the Great Mechanist. It is a sterile, circular stone room designed specifically to test the physical and magical capabilities of adventurers. The laws of nature are strictly enforced here by the 'Rules of the Engine'. Objects and entities in this room are clearly labeled and serve specific testing purposes. The Gamemaster should act as a neutral observer, ensuring that all interactions (equipping, consuming, fighting, lifting) follow the defined RPG mechanics and update the player's stats accurately.",
    "strict_rules": true,
    "selected_tone": "clinical",
    "time_per_turn": 1,
    "pacing_minutes": 1,
    "generate_scene_images": true,
    "generate_npc_images": true,
    "generate_item_images": true
  },
